{
  "cleanUrls": true,
  "routes": [
    { "src": "/api/chat", "dest": "api/chat.js" },
    { "src": "/api/weather", "dest": "api/weather.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/service-worker.js", "dest": "/service-worker.js" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
